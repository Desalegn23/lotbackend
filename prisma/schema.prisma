generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String?       @unique
  telegramId   String?       @unique
  phone        String        @unique
  password     String
  role         Role          @default(USER)
  status       UserStatus    @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  agent        Agent?        @relation("UserIsAgent") // Existing relation: User IS an agent
  
  // Permanent Agent Scope: Who referred this user
  agentId         String?
  referringAgent  Agent?      @relation("AgentReferrals", fields: [agentId], references: [id])
  
  reservations Reservation[]
}

model Agent {
  id            String    @id @default(uuid())
  userId        String    @unique
  createdAt     DateTime  @default(now())
  commissionRate Float     @default(10.0) // Admin's % cut of the profit
  
  // Payment Methods
  paymentOptions PaymentOption[]
  
  // Notification Settings
  notifyInterval  String    @default("4H") // DISABLED, 1M, 5M, 15M, 30M, 1H, 2H, 4H, 12H, DAILY
  notifyThreshold Int       @default(20)   // Percentage of tickets remaining
  notifyLanguage  String    @default("EN") // EN, AM
  notifyShowHolders Boolean @default(false) // Whether to list reservers in notifications
  customMessage   String?   // Custom Amharic/English message template
  
  user          User            @relation("UserIsAgent", fields: [userId], references: [id])
  lotteries     Lottery[]
  telegramGroups TelegramGroup[]
  
  // Referrals
  referredUsers User[]          @relation("AgentReferrals")
}

model PaymentOption {
  id            String  @id @default(uuid())
  agentId       String
  methodName    String  // e.g., "Telebirr", "CBE"
  accountNumber String
  accountName   String? // Name on the account
  instructions  String? // Optional notes for the user
  agent         Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model Lottery {
  id                String              @id @default(uuid())
  agentId           String
  title             String
  description       String?
  ticketPrice       Float
  totalTickets      Int
  status            LotteryStatus       @default(ACTIVE)
  category          String            @default("OTHER")
  image             String?
  drawn             Boolean             @default(false)
  drawnAt           DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Notification Overrides (if null, use Agent defaults)
  notifyInterval    String?
  notifyThreshold   Int?
  notifyLanguage    String?
  notifyShowHolders Boolean?
  customMessage     String?
  telegramGroupIds  String[]
  agent             Agent               @relation(fields: [agentId], references: [id])
  prizeDistribution PrizeDistribution[]
  reservations      Reservation[]
  tickets           Ticket[]
  winners           Winner[]

  @@index([agentId])
}

model PrizeDistribution {
  id          String     @id @default(uuid())
  lotteryId   String
  position    Int
  prizeAmount String
  description String?
  prizeType   PrizeType?
  lottery     Lottery    @relation(fields: [lotteryId], references: [id])

  @@unique([lotteryId, position])
}

model Ticket {
  id                 String              @id @default(uuid())
  lotteryId          String
  ticketNumber       Int
  status             TicketStatus        @default(AVAILABLE)
  createdAt          DateTime            @default(now())
  reservedBy         String?
  reservationTickets ReservationTicket[]
  lottery            Lottery             @relation(fields: [lotteryId], references: [id])
  winners            Winner[]

  @@unique([lotteryId, ticketNumber])
  @@index([lotteryId])
}

model Reservation {
  id               String              @id @default(uuid())
  lotteryId        String
  userId           String?
  name             String
  email            String?
  phone            String
  reservedByAgent  Boolean             @default(false)
  paymentConfirmed Boolean             @default(false)
  status           ReservationStatus   @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  lottery          Lottery             @relation(fields: [lotteryId], references: [id])
  user             User?               @relation(fields: [userId], references: [id])
  tickets          ReservationTicket[]

  @@index([lotteryId])
}

model ReservationTicket {
  id            String      @id @default(uuid())
  reservationId String
  ticketId      String
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  ticket        Ticket      @relation(fields: [ticketId], references: [id])

  @@unique([reservationId, ticketId])
}

model Winner {
  id            String     @id @default(uuid())
  lotteryId     String
  ticketId      String
  prizePosition Int
  prizeAmount   String
  drawnAt       DateTime   @default(now())
  description   String?
  prizeType     PrizeType?
  lottery       Lottery    @relation(fields: [lotteryId], references: [id])
  ticket        Ticket     @relation(fields: [ticketId], references: [id])

  @@unique([lotteryId, ticketId])
}

enum PrizeType {
  CASH
  PHYSICAL
  EXPERIENCE
}

enum Role {
  ADMIN
  AGENT
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum LotteryStatus {
  DRAFT
  ACTIVE
  COMPLETED
}

enum TicketStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
}

model TelegramGroup {
  id        String   @id @default(uuid())
  chatId    String   @unique
  groupName String?
  agentId   String
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id])
}

model TelegramLead {
  id         String   @id @default(uuid())
  telegramId String   @unique
  agentId    String?  // Captured when they first join the bot
  createdAt  DateTime @default(now())
}

